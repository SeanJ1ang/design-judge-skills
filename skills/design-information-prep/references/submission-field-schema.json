{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Design Award Submission Field Specification",
  "type": "object",
  "required": ["schema_version", "award_id", "program", "cycle", "checked_on", "official_sources", "routes"],
  "properties": {
    "schema_version": {"const": 1},
    "award_id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
    "program": {"type": "string", "minLength": 1},
    "cycle": {"type": "string", "minLength": 4},
    "checked_on": {"type": "string", "format": "date"},
    "official_sources": {"type": "array", "minItems": 1, "items": {"type": "string", "format": "uri"}},
    "notes": {"type": "array", "items": {"type": "string"}},
    "routes": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object",
        "required": ["route_id", "label", "fields"],
        "properties": {
          "route_id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
          "label": {"type": "string", "minLength": 1},
          "applies_when": {"type": "string"},
          "fields": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/field"}}
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "field": {
      "type": "object",
      "required": ["field_id", "label", "required", "value_type", "language", "source_facts", "essential_facts", "drafting_instructions"],
      "properties": {
        "field_id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
        "label": {"type": "string", "minLength": 1},
        "required": {"type": "boolean"},
        "value_type": {"enum": ["string", "list"]},
        "language": {"type": "string", "minLength": 1},
          "max_length": {"type": "integer", "minimum": 1},
          "min_length": {"type": "integer", "minimum": 1},
        "length_unit": {"enum": ["words", "characters"]},
        "max_items": {"type": "integer", "minimum": 1},
        "item_max_length": {"type": "integer", "minimum": 1},
        "item_length_unit": {"enum": ["words", "characters"]},
        "source_facts": {"type": "array", "items": {"type": "string"}},
        "essential_facts": {"type": "array", "items": {"type": "string"}},
        "drafting_instructions": {"type": "string", "minLength": 1},
        "publicity": {"enum": ["public_if_awarded", "jury_only", "not_stated", "administrative"]},
        "notes": {"type": "string"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
