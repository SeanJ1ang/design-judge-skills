      "fields": [
        {"field_id":"general-name","label":"General name","required":true,"value_type":"string","language":"English","max_length":50,"length_unit":"characters","source_facts":["project_type","product_type"],"essential_facts":["product_type"],"drafting_instructions":"Use a plain generic term that identifies what the entry is.","publicity":"public_if_awarded"},
        {"field_id":"proper-name","label":"Proper name","required":true,"value_type":"string","language":"English","max_length":150,"length_unit":"characters","source_facts":["project_name"],"essential_facts":["project_name"],"drafting_instructions":"Use the official product, service, or project name.","publicity":"public_if_awarded"},
        {"field_id":"specification","label":"Specification","required":true,"value_type":"string","language":"English","max_length":300,"length_unit":"characters","source_facts":["specifications","physical_dimensions","materials","core_technology","launch_status","launch_date"],"essential_facts":["specifications"],"drafting_instructions":"List the decision-relevant specifications compactly.","publicity":"public_if_awarded"},
        {"field_id":"overview","label":"Overview","required":true,"value_type":"string","language":"English","max_length":400,"length_unit":"characters","source_facts":["positioning","target_user","problem","solution","core_functions","user_benefit"],"essential_facts":["solution"],"drafting_instructions":"Define what the entry is, who it serves, and its principal value.","publicity":"public_if_awarded"},
