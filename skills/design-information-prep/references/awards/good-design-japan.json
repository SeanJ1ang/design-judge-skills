        {"field_id":"realization-process-outcome","label":"Process and outcome of design realization","required":true,"value_type":"string","language":"English","max_length":800,"length_unit":"characters","source_facts":["development_process","research_methods","prototype_iterations","testing_validation","measured_outcomes","solution","innovation_points"],"essential_facts":["development_process"],"drafting_instructions":"Describe the design process, decisive iterations, validation, and resulting outcome.","publicity":"jury_only"},
        {"field_id":"improvements-differences","label":"Improvements and differences","required":false,"value_type":"string","language":"English","max_length":800,"length_unit":"characters","source_facts":["existing_alternatives","competitive_difference","innovation_points","measured_outcomes"],"essential_facts":[],"drafting_instructions":"Compare only against evidenced prior or competing approaches.","publicity":"jury_only"},
        {"field_id":"achievements","label":"Achievements","required":false,"value_type":"string","language":"English","max_length":800,"length_unit":"characters","source_facts":["measured_outcomes","business_value","social_impact","environmental_impact","previous_awards"],"essential_facts":[],"drafting_instructions":"Report verified outcomes and recognition; avoid projections presented as results.","publicity":"jury_only"},
        {"field_id":"intellectual-property","label":"Intellectual property","required":false,"value_type":"string","language":"English","max_length":200,"length_unit":"characters","source_facts":["intellectual_property"],"essential_facts":[],"drafting_instructions":"State only filed, granted, registered, or otherwise confirmed rights.","publicity":"administrative"},
        {"field_id":"marketing-information","label":"Marketing information","required":false,"value_type":"string","language":"English","max_length":100,"length_unit":"characters","source_facts":["launch_status","launch_date","market_region","retail_price","sales_channels"],"essential_facts":[],"drafting_instructions":"Give concise, verified market availability information.","publicity":"administrative"}
