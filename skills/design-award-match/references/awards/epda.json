      "label": "Professional Product",
      "entrant_types": ["individual", "professional", "studio", "company", "university", "research_institution"],
      "project_states": ["working_prototype", "ready_for_market", "launched_product", "service_or_system", "digital_product"],
      "required_project_fields": ["completion_or_estimated_date", "original_work_and_publication_rights_confirmed"],
      "stable_constraints": [{"field": "original_work_and_publication_rights_confirmed", "operator": "truthy", "message": "The entrant must hold all rights needed for participation and publication."}],
      "dynamic_gates": ["current_cycle_open", "current_finished_project_rolling_age_window", "current_professional_categories", "current_submission_requirements"]
    },
    {
      "route_id": "professional-concept",
      "label": "Professional Conceptual",
      "entrant_types": ["individual", "professional", "studio", "company", "university", "research_institution"],
      "project_states": ["professional_concept", "working_prototype"],
      "required_project_fields": ["not_produced_or_marketed_confirmed", "original_work_and_publication_rights_confirmed"],
      "stable_constraints": [
        {"field": "not_produced_or_marketed_confirmed", "operator": "truthy", "message": "The Conceptual route is for work not yet produced or placed on the market."},
        {"field": "original_work_and_publication_rights_confirmed", "operator": "truthy", "message": "The entrant must hold all rights needed for participation and publication."}
      ],
      "dynamic_gates": ["current_cycle_open", "current_conceptual_subcategories", "current_submission_requirements"]
    },
    {
      "route_id": "student",
      "label": "Emerging European Product Design Award — Student",
      "entrant_types": ["student", "university"],
      "project_states": ["student_concept", "working_prototype", "ready_for_market", "launched_product", "service_or_system", "digital_product"],
      "required_project_fields": ["current_student_status", "university_name", "original_work_and_publication_rights_confirmed"],
      "stable_constraints": [
        {"field": "current_student_status", "operator": "truthy", "message": "The Emerging student route requires current student status unless the current rules say otherwise."},
        {"field": "original_work_and_publication_rights_confirmed", "operator": "truthy", "message": "The entrant must hold all rights needed for participation and publication."}
      ],
      "dynamic_gates": ["current_cycle_open", "current_student_program_rules", "current_finished_project_rolling_age_window", "current_categories", "current_submission_requirements"]
    }
